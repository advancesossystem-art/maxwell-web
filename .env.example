# Site
NEXT_PUBLIC_SITE_URL=https://maxwellelectrodeal.com

# Search Console / Bing (optional — paste verification codes after domain setup)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# Brand intro: full | minimal | disabled (override in dev: ?intro_mode=minimal)
NEXT_PUBLIC_INTRO_MODE=full

# Analytics (optional — enable for launch)
NEXT_PUBLIC_GTM_ID=GTM-TFSNMLRK
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-S133R6RG68
NEXT_PUBLIC_META_PIXEL_ID=

# CRM webhooks (optional)
LEAD_WEBHOOK_URL=
HUBSPOT_WEBHOOK_URL=
ZOHO_WEBHOOK_URL=
SALESFORCE_WEBHOOK_URL=

# —— Form → email alerts (required for live site) ——
# All form submissions notify this inbox:
LEAD_NOTIFICATION_EMAIL=maxwellitsolution05@gmail.com

# Gmail SMTP (recommended — uses Google App Password)
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=maxwellitsolution05@gmail.com
SMTP_PASS=
SMTP_FROM=Maxwell Electrodeal <maxwellitsolution05@gmail.com>

# Optional — Resend instead (set EMAIL_PROVIDER=resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Maxwell Electrodeal <notifications@maxwellelectrodeal.com>

# Security (production)
# Block /admin unless ?token= matches (generate a long random string, min 16 chars)
ADMIN_AUDIT_TOKEN=
# Set to "true" only if you want the demo client portal public in production
ENABLE_PORTAL_DEMO=false
# Optional Bearer token sent on outbound CRM/webhook POSTs
LEAD_WEBHOOK_SECRET=
