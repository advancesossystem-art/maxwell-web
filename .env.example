# Site
NEXT_PUBLIC_SITE_URL=https://maxwellelectrodeal.com

# Search Console / Bing (optional — paste verification codes after domain setup)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# Brand intro: full | minimal | disabled (override in dev: ?intro_mode=minimal)
NEXT_PUBLIC_INTRO_MODE=disabled

# Analytics — REQUIRED for GA4 traffic (set in Vercel Production env)
# Use GTM OR direct GA4. If GTM is set, GA4 tag must exist inside the GTM container.
NEXT_PUBLIC_GTM_ID=GTM-TFSNMLRK
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-S133R6RG68
NEXT_PUBLIC_META_PIXEL_ID=
# Microsoft Clarity session replay (optional — paste project ID from clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Scheduling — Calendly embed on thank-you & discovery pages (full https://calendly.com/... URL)
NEXT_PUBLIC_CALENDLY_URL=

# CRM webhooks (optional)
LEAD_WEBHOOK_URL=
HUBSPOT_WEBHOOK_URL=
ZOHO_WEBHOOK_URL=
SALESFORCE_WEBHOOK_URL=

# —— Form → Gmail ——
# Option A (local dev): App Password — https://myaccount.google.com/apppasswords
GMAIL_USER=maxwellelectrodealsystems@gmail.com
GMAIL_APP_PASSWORD=
LEAD_NOTIFICATION_EMAIL=maxwellelectrodealsystems@gmail.com

# Option B (production on Vercel — no App Password on hosting):
# Deploy scripts/gmail-form-relay.gs → paste Web app URL here or in src/lib/gmail-script-config.ts
# GMAIL_APPS_SCRIPT_URL=
# Optional shared secret — set RELAY_SECRET in Apps Script project properties to match
# GMAIL_APPS_SCRIPT_SECRET=

# Google Business Profile review count — only set when synced from a live GBP listing
# GOOGLE_BUSINESS_REVIEW_COUNT=

# Security (production)
# Block /admin unless ?token= matches (generate a long random string, min 16 chars)
ADMIN_AUDIT_TOKEN=
# Rate limiting (production — create free DB at https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GTM Consent Mode v2: defaults are set in app code (ConsentModeDefaults).
# In GTM: Admin → Container Settings → Enable consent overview → set all tags to
# require consent (Analytics + Ads). No tags should fire before consent update.
# Optional Bearer token sent on outbound CRM/webhook POSTs
LEAD_WEBHOOK_SECRET=
